name: Deploy cicddev

on:
  push:
    branches: [cicddev]
  workflow_dispatch:        # adds a "Run workflow" button for manual testing

permissions:
  id-token: write           # lets this run authenticate to AWS via OIDC
  contents: read            # lets it check out  repo

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Check out the code
        uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build the site
        run: npm run build

      - name: Authenticate to AWS
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::981651290900:role/gha-cicddev-deploy
          aws-region: us-east-1

      - name: Upload build to S3
        run: aws s3 sync dist/ "s3://cicddev-kiwivoiceassistant/cicddev/${{ github.sha }}/" --delete

      - name: Release on EC2
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          script: /usr/local/bin/release-cicddev.sh ${{ github.sha }}
